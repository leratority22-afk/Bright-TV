---Split by Gender on User profile
SELECT GENDER, 
     COUNT(userID) AS Male_Female_split
FROM `workspace`.`default`.`userprpfile`
GROUP BY GENDER
ORDER BY Male_Female_split DESC;

---------------------------------------------------------------------------------
---viewers split by gender
 SELECT 
      CASE 
          WHEN u.AGE IS NULL THEN 'Unknown'
          WHEN u.AGE < 13 THEN 'Child'
          WHEN u.AGE >= 13 AND u.AGE < 18 THEN 'Teen'
          WHEN u.AGE >= 18 AND u.AGE < 30 THEN 'Young Adult'
          WHEN u.AGE >= 30 AND u.AGE < 50 THEN 'Adult' 
          WHEN u.AGE >= 50 AND u.AGE < 65 THEN 'Middle Aged'
          When u.age >= 65 THEN 'Senior'
          ELSE 'Othe'
      END AS AGE_GROUP,
      COUNT(v.UserID0) AS USER_COUNT
 FROM  `workspace`.`default`.`viewer_profile` v
 LEFT JOIN `workspace`.`default`.`userprpfile` u
 ON v.UserID0 = u.UserID
 GROUP BY AGE_GROUP 
 ORDER BY USER_COUNT DESC;
    
------------------------------------------------------------------
--- Replacing NULL Value and separating the timestamp
SELECT 
    IFNULL(ROUND(u.USERID,0),'0') AS USER_ID,
    IFNULL(u.GENDER, 'NO_Gender') AS GENDER,
    IFNULL(u.RACE, 'NO_Race') AS RACE,
    IFNULL(ROUND(u.AGE,0),'0') AS AGE,
    IFNULL(u.PROVINCE, 'NO_Province') AS PROVINCE,
    IFNULL(v.CHANNEL2, 'NO_Channel') AS CHANNEL2,
    v.RECORDDATE2 AS RECORDDATE2,
    v.RECORDDATE2 AS TIMESTAMP_VALUE,
    CAST(v.RECORDDATE2 AS DATE) AS DATE_PART,
    TO_CHAR(v.RECORDDATE2, 'HH:mm:ss') AS TIME_PART
FROM `workspace`.`default`.`userprpfile` u
LEFT JOIN `workspace`.`default`.`viewer_profile` v
ON u.USERID = v.USERID0;
