----Joining the user and the viwers table

SELECT* 
FROM `workspace`.`default`.`userprpfile` up
     INNER JOIN viewer_profile vp
     ON up.UserID = UserID0;

SELECT A.UserID,
       A.Gender,
       A.Race,
       A.Province,
       A.Age,
       B.Channel2,
       B.RecordDate2,
       B.`Duration 2`
FROM userprpfile AS A
FULL OUTER JOIN viewer_profile AS B
ON A.UserID = B.UserID0;

--------------------------------------------------------------------------

---Coverting UTC time to SA time
SELECT*,
      from_utc_timestamp(v.RecordDate2, 'Africa/Johannesburg') AS sast_timestamp
FROM `workspace`.`default`.`viewer_profile` v;



----------------------------------------------------------------------------
---Count users by province

SELECT COUNT(UserID) AS User_count_by_Province  
FROM `workspace`.`default`.`userprpfile`
GROUP BY Province 
ORDER BY User_count_by_Province DESC;



--------------------------------------------------------------------------------
---Most watched shows by viewers

SELECT CHANNEL2,
      COUNT(UserID0) AS Channel2_viewerprofile
      FROM `workspace`.`default`.`viewer_profile`
      GROUP BY CHANNEL2
      ORDER BY Channel2_viewerprofile DESC;



---------------------------------------------------------------------------------

SELECT 
     CASE 
         WHEN DATE_FORMAT(RecordDate2, 'HH:mm:ss') BETWEEN '05:00:00' AND '11:59:59' THEN 'Morning_viewing'
         WHEN DATE_FORMAT(RecordDate2, 'HH:mm:ss') BETWEEN '12:00:00' AND '17:59:59' THEN 'Afternoon_viewing'
         WHEN DATE_FORMAT(RecordDate2, 'HH:mm:ss') BETWEEN '18:00:00' AND '23:59:59' THEN 'Evening_viewing'
         Else 'Midnight_viewing'
      END AS Viewing_slot,
      COUNT(UserID0) AS USER_COUNT 
FROM `workspace`.`default`.`viewer_profile`
GROUP BY Viewing_slot
ORDER BY User_Count DESC;

